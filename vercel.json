{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/*.py": {
      "runtime": "vercel-python@3.2.0"
    }
  },
  "routes": [
    { "src": "/api/news", "dest": "/api/news_supabase.py" },
    { "src": "/api/categories", "dest": "/api/categories_supabase.py" },
    { "src": "/(.*)", "dest": "/dist/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}